. program define _mk_educ_group
  1.     capture drop educ_group
  2.     gen byte educ_group = .
  3.     replace educ_group = 1 if educ_yrs < 12
  4.     replace educ_group = 2 if educ_yrs == 12
  5.     replace educ_group = 3 if inrange(educ_yrs,13,15)
  6.     replace educ_group = 4 if educ_yrs == 16
  7.     replace educ_group = 5 if educ_yrs >= 17 & !missing(educ_yrs)
  8.     capture label drop educ_group_lbl
  9.     label define educ_group_lbl 1 "no hs" 2 "hs" 3 "some college" 4 "4yr deg
> ree" 5 "grad"
 10.     label values educ_group educ_group_lbl
 11.     label variable educ_group "Education group"
 12. end

