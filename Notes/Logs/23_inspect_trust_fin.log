. foreach trust_agg in trust_fin_pc1_2020 trust_fin_pc2_2020 trust_fin_avg_2020
>  {
  2.     local agg_lab = "`trust_agg'"
  3.     if "`trust_agg'"=="trust_fin_pc1_2020" local agg_lab "PC1 (no general)
> "
  4.     if "`trust_agg'"=="trust_fin_pc2_2020" local agg_lab "PC2 (no general)
> "
  5.     if "`trust_agg'"=="trust_fin_avg_2020" local agg_lab "Avg (banks, advi
> sors, mutual funds)"
  6.     display _n "--- `agg_lab': `trust_agg' ---"
  7.     gen byte _samp = !missing(r5_annual_avg_w5) & !missing(`trust_agg')
  8.     quietly count if _samp
  9.     display "N = " r(N)
 10.     eststo clear
 11.     eststo m1: regress r5_annual_avg_w5 `ctrl_r5' if _samp, vce(robust)
 12.     estadd scalar p_joint_trust = . : m1
 13.     eststo m2: regress r5_annual_avg_w5 `ctrl_r5' c.`trust_agg' if _samp, 
> vce(robust)
 14.     estadd scalar p_joint_trust = . : m2
 15.     eststo m3: regress r5_annual_avg_w5 `ctrl_r5' c.`trust_agg' c.`trust_a
> gg'#c.`trust_agg' if _samp, vce(robust)
 16.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 17.     estadd scalar p_joint_trust = r(p) : m3
 18.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 19.     drop _samp
 20. }

