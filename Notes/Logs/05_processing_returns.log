. 
. * Winsorized names: stub_win_YYYY so 10_build_panel reshape long finds r1_ann
> ual_win_*, r4_annual_win_*, r5_annual_win_*
. local retwin ""

. foreach v of local retvars {
  2.     capture confirm numeric variable `v'
  3.     if !_rc {
  4.         quietly summarize `v', detail
  5.         local p1 = r(p1)
  6.         local p99 = r(p99)
  7.         if regexm("`v'", "_([0-9]{4})$") {
  8.             local vyear = regexs(1)
  9.             local vstub = regexr("`v'", "_[0-9]{4}$", "")
 10.             capture drop `vstub'_win_`vyear'
 11.             gen double `vstub'_win_`vyear' = `v'
 12.             replace `vstub'_win_`vyear' = `p1' if `vstub'_win_`vyear' < `p
> 1' & !missing(`vstub'_win_`vyear')
 13.             replace `vstub'_win_`vyear' = `p99' if `vstub'_win_`vyear' > `
> p99' & !missing(`vstub'_win_`vyear')
 14.             local retwin "`retwin' `vstub'_win_`vyear'"
 15.         }
 16.         else {
 17.             capture drop `v'_win
 18.             gen double `v'_win = `v'
 19.             replace `v'_win = `p1' if `v'_win < `p1' & !missing(`v'_win)
 20.             replace `v'_win = `p99' if `v'_win > `p99' & !missing(`v'_win)
 21.             local retwin "`retwin' `v'_win"
 22.         }
 23.     }
 24. }
