138.         if !_rc local ctrl_fe "`ctrl_fe' wealth_d`d'"
139.     }
140.     local ctrl_fe "`ctrl_fe' c.share_core##i.year c.share_ira##i.year c.shar
> e_res##i.year c.share_debt_long##i.year c.share_debt_other##i.year"
141.     gen byte _fe_cond = `share_cond' & !missing(`trust_agg')
142.     capture drop _fe_r5 fe_r5
143.     quietly xtreg r5_annual_w5 `ctrl_fe' if _fe_cond, fe vce(cluster hhidpn)
144.     if _rc {
145.         display "  xtreg failed for `trust_agg'"
146.         drop _samp _fe_cond
147.         continue
148.     }
149.     predict _fe_r5 if e(sample)
150.     bysort hhidpn: egen fe_r5 = mean(_fe_r5)
151.     preserve
152.     keep if !missing(fe_r5)
153.     keep hhidpn fe_r5 educ_yrs gender race_eth born_us `trust_agg'
154.     collapse (first) fe_r5 educ_yrs gender race_eth born_us `trust_agg', by(
> hhidpn)
155.     gen byte _fe_samp = !missing(fe_r5) & !missing(`trust_agg')
156.     quietly count if _fe_samp
157.     display "  N (persons) = " r(N)
158.     if "`trust_agg'" == "trust_fin_avg_2020" {
159.         quietly summarize fe_r5 if _fe_samp, detail
160.         local p1 = r(p1)
161.         local p99 = r(p99)
162.         gen double fe_r5_w1 = fe_r5
163.         replace fe_r5_w1 = `p1' if fe_r5_w1 < `p1' & _fe_samp
164.         replace fe_r5_w1 = `p99' if fe_r5_w1 > `p99' & _fe_samp
165.         twoway scatter fe_r5_w1 `trust_agg' if _fe_samp, msize(tiny) msymbol
> (circle) ///
>             title("FE vs Trust in Fin. Institutions (${LATEX_WIN_SHORT})") ///
>             xtitle("Trust in Fin. Institutions") ytitle("Estimated FE") ///
>             scheme(s2color)
166.         graph export "${REGRESSIONS}/Trust/FinInst/Figures/fe_vs_trust_finin
> st_avg.png", replace width(1200)
167.         di as txt "Wrote: fe_vs_trust_fininst_avg.png"
168.         drop fe_r5_w1
169.     }
170.     local keep_p3 "`trust_agg' c.`trust_agg'#c.`trust_agg' educ_yrs 2.gender
>  2.race_eth 3.race_eth 4.race_eth born_us _cons"
171.     eststo clear
172.     eststo m1: regress fe_r5 educ_yrs i.gender i.race_eth born_us if _fe_sam
> p, vce(robust)
173.     estadd scalar p_joint_trust = . : m1
174.     quietly testparm i.race_eth
175.     estadd scalar p_joint_race = r(p) : m1
176.     eststo m2: regress fe_r5 educ_yrs i.gender i.race_eth born_us c.`trust_a
> gg' if _fe_samp, vce(robust)
177.     estadd scalar p_joint_trust = . : m2
178.     quietly testparm i.race_eth
179.     estadd scalar p_joint_race = r(p) : m2
180.     eststo m3: regress fe_r5 educ_yrs i.gender i.race_eth born_us c.`trust_a
> gg' c.`trust_agg'#c.`trust_agg' if _fe_samp, vce(robust)
181.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
182.     estadd scalar p_joint_trust = r(p) : m3
183.     quietly testparm i.race_eth
184.     estadd scalar p_joint_race = r(p) : m3
185.     esttab m1 m2 m3 using "`FININST_TAB'/fin_trust_`stub'_panel3.tex", repla
> ce ///
>         booktabs mtitles("(1)" "(2)" "(3)") ///
>         se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) label ///
>         keep(`keep_p3') ///
>         varlabels(`trust_agg' "Trust" c.`trust_agg'#c.`trust_agg' "Trust\$^2\$"
>  ///
>             educ_yrs "Years education" 2.gender "Female" 2.race_eth "NH Black" 
> 3.race_eth "Hispanic" 4.race_eth "NH Other" born_us "Born in U.S.") ///
>         stats(N r2_a p_joint_trust p_joint_race, labels("Observations" "Adj. R-
> squared" "Joint test: Trust p-value" "Joint test: Race p-value")) ///
>         title("Panel Spec 3 (FE, 2nd stage): r5 returns on financial-institutio
> nal trust`ttag'") ///
>         addnotes(".") ///
>         alignment(${LATEX_ALIGN}) width(0.85\hsize) nonumbers nonotes
186.     restore
187.     drop _fe_r5 fe_r5 _samp _fe_cond
188. }
