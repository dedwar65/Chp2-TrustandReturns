 26.     }
 27.     if `has_gender_ctrl' & trim("`reg_ctrl_gender'") != "" {
 28.         display "--- Joint test: Gender ---"
 29.         testparm i.gender
 30.     }
 31. 
.     display _n "--- Trust squared on IV baseline controls + instruments ---"
