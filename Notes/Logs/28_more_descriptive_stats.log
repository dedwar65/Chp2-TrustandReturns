. file write fh4 "\begin{table}[htbp]\centering\small" _n ///
>     "\caption{Returns to assets/portfolios}" _n ///
>     "\label{tab:returns_portfolio_moments_pooled}" _n ///
>     "\begin{tabular}{lrrrrrrr}\toprule" _n ///
