. * ----------------------------------------------------------------------
. * Step D: Second-stage regressions (FE on time-invariant vars)
. * One table per return measure (r1, r4, r5) × raw/winsorized
. * ----------------------------------------------------------------------
. foreach win in raw win {
  2.     local win_label "raw"
  3.     if "`win'" == "win" local win_label "${LATEX_WIN_SHORT}"
  4.     foreach ret in r1 r4 r5 {
  5.         use `fe_append', clear
  6.         keep if ret_type=="`ret'" & win_type=="`win'"
  7.         drop if missing(educ_yrs) | missing(gender) | missing(race_eth)
  8. 
.         local ret_label "returns to core"
  9.         if "`ret'" == "r4" local ret_label "returns to core and IRA"
 10.         if "`ret'" == "r5" local ret_label "returns to net wealth"
 11. 
.         eststo clear
 12.         eststo m1: regress fe educ_yrs i.gender i.race_eth born_us, vce(ro
> bust)
 13.         estadd scalar p_joint_trust = . : m1
 14.         quietly testparm i.race_eth
 15.         estadd scalar p_joint_race = r(p) : m1
 16.         eststo m2: regress fe educ_yrs i.gender i.race_eth born_us trust_o
> thers_2020 if !missing(trust_others_2020), vce(robust)
 17.         estadd scalar p_joint_trust = . : m2
 18.         quietly testparm i.race_eth
 19.         estadd scalar p_joint_race = r(p) : m2
 20.         eststo m3: regress fe educ_yrs i.gender i.race_eth born_us trust_o
> thers_2020 c.trust_others_2020#c.trust_others_2020 if !missing(trust_others_2
> 020), vce(robust)
 21.         quietly testparm trust_others_2020 c.trust_others_2020#c.trust_oth
> ers_2020
 22.         estadd scalar p_joint_trust = r(p) : m3
 23.         quietly testparm i.race_eth
 24.         estadd scalar p_joint_race = r(p) : m3
 25. 
.         * Display full second-stage in log (all coefficients) — for history o
> f actual results
.         esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) label //
> /
>             mtitles("(1)" "(2)" "(3)") ///
>             stats(N r2_a p_joint_trust p_joint_race, labels("Observations" "A
> dj. R-squared" "Joint test: Trust p-value" "Joint test: Race p-value")) ///
>             title("Second-stage: FE from `ret_label' (`win_label') — full res
> ults")
 26. 
.         local keep_list "educ_yrs 2.gender 2.race_eth 3.race_eth 4.race_eth b
> orn_us trust_others_2020 c.trust_others_2020#c.trust_others_2020 _cons"
 27.         local outfile "${REGRESSIONS}/Panel/panel_fe_on_tinv_`ret'_`win'.t
> ex"
 28.         local tablabel "tab:panel_fe_on_tinv_`ret'_`win'"
 29.         esttab m1 m2 m3 using "`outfile'", replace ///
>             booktabs ///
>             mtitles("(1)" "(2)" "(3)") ///
>             se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) label ///
>             keep(`keep_list') ///
>             varlabels(educ_yrs "Years of education" 2.gender "Female" 2.race_
> eth "NH Black" 3.race_eth "Hispanic" 4.race_eth "NH Other" born_us "Born in U
> .S." trust_others_2020 "Trust" c.trust_others_2020#c.trust_others_2020 "Trust
> \$^2\$" _cons `"\_cons"') ///
>             stats(N r2_a p_joint_trust p_joint_race, labels("Observations" "A
> dj. R-squared" "Joint test: Trust p-value" "Joint test: Race p-value")) ///
>             title("Second-stage: FE from `ret_label' (`win_label') on time-in
> variant vars") ///
>             addnotes(".") ///
>             alignment(${LATEX_ALIGN}) width(0.85\hsize) nonumbers nonotes sub
> stitute("\caption{" "\caption[]{")
 30. 
.         di as txt "Wrote: panel_fe_on_tinv_`ret'_`win'.tex"
 31.     }
 32. }
