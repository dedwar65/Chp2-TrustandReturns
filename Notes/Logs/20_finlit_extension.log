> racy: Literacy score (0--3) frequency}" _n "\label{tab:finlit_freq}" _n "\begin
> {tabular}{lrr}\toprule" _n "Literacy score & N & Pct \\\\ \midrule" _n

. forvalues r = 1/`=_N' {
