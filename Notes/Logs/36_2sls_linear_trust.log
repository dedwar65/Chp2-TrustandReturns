. * ----------------------------------------------------------------------
. * 4) First-stage trust diagnostics by instrument scheme
. * ----------------------------------------------------------------------
. display _n "#################################################################
> #######"

########################################################################

. display "4) FIRST-STAGE TRUST DIAGNOSTICS BY INSTRUMENT SCHEME"
4) FIRST-STAGE TRUST DIAGNOSTICS BY INSTRUMENT SCHEME

. display "####################################################################
> ####"
########################################################################

. 
. foreach s of local scheme_list {
  2.     if !`scheme_has_`s'' continue
  3. 
.     local scheme_label "`scheme_label_`s''"
  4.     local instrs "`scheme_instr_`s''"
  5.     local stage_ctrls "`scheme_ctrls_`s''"
  6.     local has_gender_ctrl `scheme_has_gender_`s''
  7.     local has_race_ctrl `scheme_has_race_`s''
  8. 
.     display _n "#############################################################
> ###########"
  9.     display "`scheme_label'"
 10.     display "#############################################################
> ###########"
 11.     display "Instrument set: `instrs'"
 12. 
.     display _n "--- Trust on IV baseline controls + instruments ---"
 13.     regress trust_others_2020 `stage_ctrls' `instrs', vce(robust)
 14.     display "--- Joint test: Instruments ---"
 15.     testparm `instrs'
 16.     if trim("`wealth_r5_vars'") != "" {
 17.         display "--- Joint test: Wealth deciles (net wealth) ---"
 18.         testparm `wealth_r5_vars'
 19.     }
 20.     if trim("`reg_ctrl_age'") != "" {
 21.         display "--- Joint test: Age bins ---"
 22.         testparm i.age_bin
 23.     }
 24.     if trim("`reg_ctrl_educ'") != "" {
 25.         display "--- Joint test: Education categories ---"
 26.         testparm i.educ_cat
 27.     }
 28.     if `has_gender_ctrl' & trim("`reg_ctrl_gender'") != "" {
 29.         display "--- Joint test: Gender ---"
 30.         testparm i.gender
 31.     }
 32.     if `has_race_ctrl' & trim("`reg_ctrl_race'") != "" {
 33.         display "--- Joint test: Race ---"
 34.         testparm i.race_eth
 35.     }
 36. }

