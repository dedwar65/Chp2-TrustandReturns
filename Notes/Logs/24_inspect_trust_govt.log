. foreach trust_agg in trust_govt_pc1_2020 trust_govt_avg_2020 {
  2.     local agg_lab = cond("`trust_agg'"=="trust_govt_pc1_2020", "PCA (no ge
> neral)", "Avg (Medicare, Social Security)")
  3.     display _n "--- `agg_lab': `trust_agg' ---"
  4.     gen byte _samp = !missing(r5_annual_avg_w5) & !missing(`trust_agg')
  5.     quietly count if _samp
  6.     display "N = " r(N)
  7.     eststo clear
  8.     eststo m1: regress r5_annual_avg_w5 `ctrl_r5' if _samp, vce(robust)
  9.     estadd scalar p_joint_trust = . : m1
 10.     eststo m2: regress r5_annual_avg_w5 `ctrl_r5' c.`trust_agg' if _samp, 
> vce(robust)
 11.     estadd scalar p_joint_trust = . : m2
 12.     eststo m3: regress r5_annual_avg_w5 `ctrl_r5' c.`trust_agg' c.`trust_a
> gg'#c.`trust_agg' if _samp, vce(robust)
 13.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 14.     estadd scalar p_joint_trust = r(p) : m3
 15.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 16.     drop _samp
 17. }

