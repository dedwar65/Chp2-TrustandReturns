> tc.
. * ---------------------------------------------------------------------
. display "=== 5% winsorization on r1/r4/r5 (all years) ==="
=== 5% winsorization on r1/r4/r5 (all years) ===

. foreach y of local years {
  2.     foreach stub in r1_annual r4_annual r5_annual {
  3.         local v `stub'_`y'
  4.         capture confirm variable `v'
  5.         if !_rc {
  6.             quietly summarize `v', detail
  7.             local p5  = r(p5)
  8.             local p95 = r(p95)
  9.             capture drop `stub'_w5_`y'
 10.             gen double `stub'_w5_`y' = `v'
 11.             replace `stub'_w5_`y' = `p5'  if `stub'_w5_`y' < `p5'  & !miss
> ing(`stub'_w5_`y')
