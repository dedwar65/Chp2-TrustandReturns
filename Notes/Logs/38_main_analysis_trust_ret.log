. * Helper: post tp from last regression
. capture program drop _post_tp

. program define _post_tp
  1.     args ctrl model
  2.     capture confirm matrix e(b)
  3.     if _rc exit
  4.     local b1 .
  5.     local b2 .
  6.     capture local b1 = _b[c.trust_others_2020]
  7.     if _rc capture local b1 = _b[trust_others_2020]
  8.     capture local b2 = _b[c.trust_others_2020#c.trust_others_2020]
  9.     if _rc capture local b2 = _b[trust_others_2020_sq]
 10.     if `b1' >= . | `b2' >= . exit
 11.     quietly test c.trust_others_2020 = 0
 12.     if _rc quietly test trust_others_2020 = 0
 13.     local p1 = r(p)
 14.     quietly test c.trust_others_2020#c.trust_others_2020 = 0
 15.     if _rc quietly test trust_others_2020_sq = 0
 16.     local p2 = r(p)
 17.     local both_sig = (`p1' < 0.10 & `p2' < 0.10)
 18.     local tp .
 19.     local tp_se .
 20.     local tp_p .
 21.     local tp_lb .
 22.     local tp_ub .
 23.     capture nlcom (tp: -_b[c.trust_others_2020]/(2*_b[c.trust_others_2020#
> c.trust_others_2020]))
 24.     if _rc == 0 {
 25.         matrix T = r(table)
 26.         local tp    = T[1,1]
 27.         local tp_se = T[2,1]
 28.         local tp_p  = T[4,1]
 29.         local tp_lb = T[5,1]
 30.         local tp_ub = T[6,1]
 31.     }
 32.     if `tp' >= . {
 33.         capture nlcom (tp: -_b[trust_others_2020]/(2*_b[trust_others_2020_
> sq]))
 34.         if _rc == 0 {
 35.             matrix T = r(table)
 36.             local tp    = T[1,1]
 37.             local tp_se = T[2,1]
 38.             local tp_p  = T[4,1]
 39.             local tp_lb = T[5,1]
 40.             local tp_ub = T[6,1]
 41.         }
 42.     }
 43.     post tpH ("`ctrl'") ("`model'") (e(N)) (`b1') (`b2') (`tp') (`tp_se') 
> (`tp_p') (`tp_lb') (`tp_ub') (`both_sig')
 44. end

