 27.         local tp_se = T[2,1]
 28.         local tp_p  = T[4,1]
 29.         local tp_lb = T[5,1]
 30.         local tp_ub = T[6,1]
 31.     }
 32.     post tpH ("returns_avg_r5_win") ("`s'") ("`y'") ("`tvar'") ///
>         (e(N)) (`b1') (`b2') (`tp') (`tp_se') (`tp_p') (`tp_lb') (`tp_ub') (`
> tmin') (`tmax') (`both_sig') (`p_joint')
 33. }

