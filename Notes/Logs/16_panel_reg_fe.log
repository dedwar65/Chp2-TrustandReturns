. 
. capture which esttab

. if _rc ssc install estout, replace

. 
. * ----------------------------------------------------------------------
. * Load long panel
. * ----------------------------------------------------------------------
. use "${PROCESSED}/analysis_final_long_unbalanced.dta", clear

. set showbaselevels off

. 
. xtset hhidpn year

Panel variable: hhidpn (strongly balanced)
 Time variable: year, 2000 to 2022, but with gaps
         Delta: 1 unit

. 
. * Require raw returns, winsorized returns, and share vars
. foreach v in r1_annual_nw r4_annual_nw r5_annual_nw share_core share_ira shar
> e_res share_debt_long share_debt_other {
  2.     capture confirm variable `v'
  3.     if _rc {
  4.         display as error "16_panel_reg_fe: `v' not found. Run 02, 03, 04, 
> 05, 10 in order."
  5.         log close
  6.         exit 198
  7.     }
  8. }

. foreach v in r1_annual_w5 r4_annual_w5 r5_annual_w5 {
  2.     capture confirm variable `v'
  3.     if _rc {
  4.         display as error "16_panel_reg_fe: `v' (winsorized) not found. Run
>  05_processing_returns.do and 10_build_panel.do."
  5.         log close
  6.         exit 198
  7.     }
  8. }

. 
. local r1_raw "r1_annual_nw"

. local r4_raw "r4_annual_nw"

. local r5_raw "r5_annual_nw"

. local trust_var "trust_others_2020"

. 
. * Time-varying controls only (no educ, gender, race, born_us, trust)
. * Region (censreg) varies by wave; include if present
. local ctrl_r1 "i.age_bin inlbrf married i.year"

. local ctrl_r4 "i.age_bin inlbrf married i.year"

. local ctrl_r5 "i.age_bin inlbrf married i.year"

. capture confirm variable censreg

. if !_rc {
.     local ctrl_r1 "i.age_bin i.censreg inlbrf married i.year"
.     local ctrl_r4 "i.age_bin i.censreg inlbrf married i.year"
.     local ctrl_r5 "i.age_bin i.censreg inlbrf married i.year"
. }

. forvalues d = 2/10 {
  2.     capture confirm variable wealth_core_d`d'
  3.     if !_rc local ctrl_r1 "`ctrl_r1' wealth_core_d`d'"
  4.     capture confirm variable wealth_coreira_d`d'
  5.     if !_rc local ctrl_r4 "`ctrl_r4' wealth_coreira_d`d'"
  6.     capture confirm variable wealth_d`d'
  7.     if !_rc local ctrl_r5 "`ctrl_r5' wealth_d`d'"
  8. }

. local ctrl_r1 "`ctrl_r1' c.share_core##i.year"

. local ctrl_r4 "`ctrl_r4' c.share_core##i.year c.share_ira##i.year"

. local ctrl_r5 "`ctrl_r5' c.share_core##i.year c.share_ira##i.year c.share_res
> ##i.year c.share_debt_long##i.year c.share_debt_other##i.year"

. 
. * Share conditions
. local share_cond_r1 "!missing(share_core)"

. local share_cond_r4 "!missing(share_core) & !missing(share_ira)"

. local share_cond_r5 "!missing(share_core) & !missing(share_ira) & !missing(sh
> are_res) & !missing(share_debt_long) & !missing(share_debt_other)"

. 
. * ----------------------------------------------------------------------
. * Step A & B: Run FE regressions, save FE, export tables (raw + winsorized)
. * Reload data before each regression (like old repo reg_fixed_effects.do) to 
> avoid dataset state issues.
. * ----------------------------------------------------------------------
. tempfile fe_append

. local first_fe 1

. 
. foreach win in raw win {
  2.     local y_suffix "nw"
  3.     local win_label "raw"
  4.     if "`win'" == "win" {
  5.         local y_suffix "w5"
  6.         local win_label "${LATEX_WIN_SHORT}"
  7.     }
  8.     foreach ret in r1 r4 r5 {
  9.         local yvar "r1_annual_`y_suffix'"
 10.         if "`ret'" == "r4" local yvar "r4_annual_`y_suffix'"
 11.         if "`ret'" == "r5" local yvar "r5_annual_`y_suffix'"
 12. 
.         * Reload fresh data before each regression (aligns with old repo reg_
> fixed_effects.do)
.         use "${PROCESSED}/analysis_final_long_unbalanced.dta", clear
 13.         xtset hhidpn year
 14. 
.         capture confirm variable `yvar'
 15.         if _rc {
 16.             di as txt "Skipping `win' `ret': `yvar' not found."
 17.             continue
 18.         }
 19. 
.         local ctrl ""
 20.         local share_cond "1"
 21.         local ret_label ""
 22.         if "`ret'" == "r1" {
 23.             local ctrl "`ctrl_r1'"
 24.             local share_cond "`share_cond_r1'"
 25.             local ret_label "returns to core"
 26.         }
 27.         if "`ret'" == "r4" {
 28.             local ctrl "`ctrl_r4'"
 29.             local share_cond "`share_cond_r4'"
 30.             local ret_label "returns to core and IRA"
 31.         }
 32.         if "`ret'" == "r5" {
 33.             local ctrl "`ctrl_r5'"
 34.             local share_cond "`share_cond_r5'"
 35.             local ret_label "returns to net wealth"
 36.         }
 37. 
.         di as txt _n "--- Spec 3 FE: `ret_label' (`win_label') ---"
 38. 
.         quietly count if !missing(`yvar') & `share_cond'
 39.         if r(N) < 100 {
 40.             di as txt "Skipping `ret' `win': too few obs (N=" r(N) ")."
 41.             continue
 42.         }
 43. 
.         * xtreg, fe (same share×year spec as Spec 2; matches old repo reg_fix
> ed_effects.do)
.         capture xtreg `yvar' `ctrl' if !missing(`yvar') & `share_cond', fe vc
> e(cluster hhidpn)
 44.         if _rc {
 45.             di as err "xtreg failed for `ret' `win' (r(" _rc ")). Skipping
> ."
 46.             continue
 47.         }
 48.         predict double __fe_resid, e
 49.         predict double __hdfe1__, u
 50. 
.         * Joint tests on uninteracted share coefficients
.         if "`ret'" == "r1" {
 51.             quietly testparm share_core
 52.             estadd scalar p_joint_share_core = r(p)
 53.         }
 54.         if "`ret'" == "r4" {
 55.             quietly testparm share_core share_ira
 56.             estadd scalar p_joint_share_asset = r(p)
 57.         }
 58.         if "`ret'" == "r5" {
 59.             quietly testparm share_core share_ira share_res
 60.             estadd scalar p_joint_share_asset = r(p)
 61.             quietly testparm share_debt_long share_debt_other
 62.             estadd scalar p_joint_share_debt = r(p)
 63.         }
 64.         * Joint tests: age bins, region, wealth deciles, year
.         quietly testparm i.age_bin
 65.         estadd scalar p_joint_age_bin = r(p)
 66.         capture testparm i.censreg
 67.         if _rc == 0 estadd scalar p_joint_censreg = r(p)
 68.         else estadd scalar p_joint_censreg = .
 69.         local wlist ""
 70.         if "`ret'" == "r1" {
 71.             forvalues d = 2/10 {
 72.                 capture confirm variable wealth_core_d`d'
 73.                 if !_rc local wlist "`wlist' wealth_core_d`d'"
 74.             }
 75.         }
 76.         if "`ret'" == "r4" {
 77.             forvalues d = 2/10 {
 78.                 capture confirm variable wealth_coreira_d`d'
 79.                 if !_rc local wlist "`wlist' wealth_coreira_d`d'"
 80.             }
 81.         }
 82.         if "`ret'" == "r5" {
 83.             forvalues d = 2/10 {
 84.                 capture confirm variable wealth_d`d'
 85.                 if !_rc local wlist "`wlist' wealth_d`d'"
 86.             }
 87.         }
 88.         if trim("`wlist'") != "" {
 89.             quietly testparm `wlist'
 90.             estadd scalar p_joint_wealth = r(p)
 91.         }
 92.         else estadd scalar p_joint_wealth = .
 93.         quietly testparm i.year
 94.         estadd scalar p_joint_year = r(p)
 95. 
.         * xtreg already stores r2_w, sigma_u, sigma_e, rho — no need to estad
> d
. 
.         * Report joint tests on uninteracted share coefficients (not share x 
> year interactions)
.         if "`ret'" == "r1" local stats_share "p_joint_share_core"
 96.         if "`ret'" == "r1" local labels_share `" "Joint test: Share core p
> -value""'
 97.         if "`ret'" == "r4" local stats_share "p_joint_share_asset"
 98.         if "`ret'" == "r4" local labels_share `" "Joint test: Share (core,
>  IRA) p-value""'
 99.         if "`ret'" == "r5" local stats_share "p_joint_share_asset p_joint_
> share_debt"
100.         if "`ret'" == "r5" local labels_share `" "Joint test: Share (core,
>  IRA, res) p-value" "Joint test: Share (debt long, other) p-value""'
101.         local stats_line "N r2_w rho sigma_u sigma_e p_joint_age_bin p_joi
> nt_censreg p_joint_wealth p_joint_year `stats_share'"
102.         local labels_line `" "Observations" "Within R²" "$\rho$" "$\sigma_
> u$" "$\sigma_e$" "Joint test: Age bins p-value" "Joint test: Region p-value" 
> "Joint test: Wealth deciles p-value" "Joint test: Year p-value" `labels_share
> '"'
103. 
.         eststo fe_`ret'_`win'
104. 
.         * Display full regression in log (all coefficients; no keep) — for hi
> story of actual results
.         esttab fe_`ret'_`win', se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) la
> bel ///
>             stats(`stats_line', labels(`labels_line')) ///
>             nomtitles nonumbers nonotes noobs
105. 
.         * Save FE to tempfile and append
.         preserve
106.         keep if e(sample)
107.         keep hhidpn __hdfe1__
108.         collapse (first) __hdfe1__, by(hhidpn)
109.         rename __hdfe1__ fe
110.         gen ret_type = "`ret'"
111.         gen win_type = "`win'"
112.         tempfile fe_`ret'_`win'
113.         save `fe_`ret'_`win''
114.         restore
115. 
.         if `first_fe' {
116.             use `fe_`ret'_`win'', clear
117.             local first_fe 0
118.         }
119.         else {
120.             use `fe_append', clear
121.             append using `fe_`ret'_`win''
122.         }
123.         save `fe_append', replace
124. 
.         * Export table — uninteracted share terms, inlbrf, married. Age bins,
>  year, wealth, share×year omitted (see note).
.         * xtreg stores binary vars as inlbrf_, married_ in e(b).
.         quietly estimates restore fe_`ret'_`win'
125.         local keep_list "inlbrf_ married_ share_core share_ira share_res s
> hare_debt_long share_debt_other _cons"
126.         if "`ret'" == "r1" local keep_list "inlbrf_ married_ share_core _c
> ons"
127.         if "`ret'" == "r4" local keep_list "inlbrf_ married_ share_core sh
> are_ira _cons"
128.         if "`ret'" == "r5" local keep_list "inlbrf_ married_ share_core sh
> are_ira share_res share_debt_long share_debt_other _cons"
129.         local order_r1 "inlbrf_ married_ share_core _cons"
130.         local order_r4 "inlbrf_ married_ share_core share_ira _cons"
131.         local order_r5 "inlbrf_ married_ share_core share_ira share_res sh
> are_debt_long share_debt_other _cons"
132.         local keep_final ""
133.         capture confirm matrix e(b)
134.         if !_rc {
135.             local bnames : colnames e(b)
136.             foreach c of local keep_list {
137.                 if `: list c in bnames' local keep_final "`keep_final' `c'
> "
138.             }
139.         }
140.         if "`keep_final'" == "" local keep_final "_cons"
141. 
.         local outfile "${REGRESSIONS}/Panel/panel_reg_`ret'_spec3.tex"
142.         if "`win'" == "win" local outfile "${REGRESSIONS}/Panel/panel_reg_
> `ret'_spec3_win.tex"
143. 
.         local tablabel "tab:panel_reg_`ret'_spec3_`win'"
144.         local omit_note1 "Age bins, wealth deciles, region dummies, year d
> ummies,"
145.         local omit_note2 "${LATEX_SHARE_YEAR} interactions included in est
> imation but omitted from table."
146.         if `: list inlbrf_ in keep_final' == 0 | `: list married_ in keep_
> final' == 0 {
147.             local omit_note2 "`omit_note2' Employed and/or Married omitted
>  (collinear with individual FE)."
148.         }
149.         local note1 "Cluster-robust SE in parentheses. Individual fixed ef
> fects."
150.         local note2 "`omit_note1'"
151.         local note3 "`omit_note2'"
152.         local note4 "\sym{*} \(p<0.10\), \sym{**} \(p<0.05\), \sym{***} \(
> p<0.01\)"
153.         esttab fe_`ret'_`win' using "`outfile'", replace ///
>             booktabs ///
>             mtitles("(1)") ///
>             se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) label ///
>             keep(`keep_final') order(`order_`ret'') ///
>             varlabels(inlbrf_ "In labor force" married_ "Married" share_core 
> "Share core" share_ira "Share IRA" share_res "Share residential" share_debt_l
> ong "Share long-term debt" share_debt_other "Share other debt" _cons `"\_cons
> "') ///
>             stats(`stats_line', labels(`labels_line')) ///
>             title("Panel Spec 3: `ret_label' (`win_label', ${LATEX_SHARE_YEAR
> })") ///
>             addnotes(".") ///
>             alignment(${LATEX_ALIGN}) width(0.85\hsize) nonumbers nonotes sub
> stitute("\caption{" "\caption[]{")
154. 
.         di as txt "Wrote: `outfile'"
155.     }
156. }

