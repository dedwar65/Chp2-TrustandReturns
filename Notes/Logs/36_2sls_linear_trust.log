. * ----------------------------------------------------------------------
. * 5) 2SLS second stage by instrument scheme (r5 only)
. * ----------------------------------------------------------------------
. display _n "#################################################################
> #######"

########################################################################

. display "5) 2SLS SECOND STAGE BY INSTRUMENT SCHEME (r5 ONLY)"
5) 2SLS SECOND STAGE BY INSTRUMENT SCHEME (r5 ONLY)

. display "####################################################################
> ####"
########################################################################

. 
. foreach s of local scheme_list {
  2.     if !`scheme_has_`s'' continue
  3. 
.     local scheme_label "`scheme_label_`s''"
  4.     local instrs "`scheme_instr_`s''"
  5.     local reg_ctrls "`scheme_ctrls_`s''"
  6.     local has_gender_ctrl `scheme_has_gender_`s''
  7.     local has_race_ctrl `scheme_has_race_`s''
  8. 
.     display _n "#############################################################
> ###########"
  9.     display "`scheme_label'"
 10.     display "#############################################################
> ###########"
 11.     display "Excluded instruments: `instrs'"
 12. 
.     local wealth_test_list "`wealth_r5_vars'"
 13. 
.     display _n "-------------------------------------------------------------
> ----------"
 14.     display "Outcome: r5_annual_avg_w5"
 15.     display "Regressions use listwise deletion; N may differ across models
> ."
 16.     display "Included exogenous controls: `reg_ctrls'"
 17.     display "Excluded instruments: `instrs'"
 18.     display "-------------------------------------------------------------
> ----------"
 19. 
.     local y "r5_annual_avg_w5"
 20. 
.     ivregress 2sls `y' `reg_ctrls' ///
>         (trust_others_2020 = `instrs'), vce(robust)
 21.     estimates store iv_`s'
 22. 
.     display _n "--- IV diagnostics: built-in (ivregress) ---"
 23.     capture noisily estat firststage
 24.     if _rc display as txt "estat firststage unavailable for this specifica
> tion."
 25.     capture noisily estat endogenous
 26.     if _rc display as txt "estat endogenous unavailable for this specifica
> tion."
 27.     capture noisily estat overid
 28.     if _rc display as txt "estat overid unavailable for this specification
> ."
 29. 
.     display _n "--- IV diagnostics: weakrobust (single endogenous) ---"
 30.     capture noisily estat weakrobust
 31.     if _rc display as txt "estat weakrobust unavailable for this specifica
> tion."
 32.     capture noisily estat weakrobust, ar
 33.     if _rc display as txt "estat weakrobust AR unavailable for this specif
> ication."
 34.     capture noisily estat weakrobust, clr
 35.     if _rc display as txt "estat weakrobust CLR unavailable for this speci
> fication."
 36. 
.     display _n "--- IV diagnostics: ivreg2 weak-ID suite ---"
 37.     capture noisily ivreg2 `y' `reg_ctrls' ///
>         (trust_others_2020 = `instrs'), ///
>         robust first
 38.     if _rc display as txt "ivreg2 diagnostics unavailable for this specifi
> cation."
 39. 
.     estimates restore iv_`s'
 40.     display "--- Test: trust_others_2020 ---"
 41.     test trust_others_2020
 42.     if trim("`wealth_test_list'") != "" {
 43.         display "--- Joint test: Wealth deciles ---"
 44.         testparm `wealth_test_list'
 45.     }
 46.     if trim("`reg_ctrl_age'") != "" {
 47.         display "--- Joint test: Age bins ---"
 48.         testparm i.age_bin
 49.     }
 50.     if trim("`reg_ctrl_educ'") != "" {
 51.         display "--- Joint test: Education categories ---"
 52.         testparm i.educ_cat
 53.     }
 54.     if `has_gender_ctrl' & trim("`reg_ctrl_gender'") != "" {
 55.         display "--- Joint test: Gender ---"
 56.         testparm i.gender
 57.     }
 58.     if `has_race_ctrl' & trim("`reg_ctrl_race'") != "" {
 59.         display "--- Joint test: Race ---"
 60.         testparm i.race_eth
 61.     }
 62. }

