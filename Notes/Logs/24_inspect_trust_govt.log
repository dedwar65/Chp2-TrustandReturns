########################################################################

. 
. use "${PROCESSED}/analysis_final_long_unbalanced.dta", clear

. merge m:1 hhidpn using `govt_trust_wide', nogen

    Result                      Number of obs
    -----------------------------------------
    Not matched                             0
    Matched                           542,808  
    -----------------------------------------

. xtset hhidpn year

Panel variable: hhidpn (strongly balanced)
 Time variable: year, 2000 to 2022, but with gaps
         Delta: 1 unit

. 
. * Base controls
. local base_ctrl "i.age_bin educ_yrs i.gender i.race_eth inlbrf married born_u
> s i.censreg"

. forvalues d = 2/10 {
  2.     capture confirm variable wealth_d`d'
  3.     if !_rc local base_ctrl "`base_ctrl' wealth_d`d'"
  4. }

. local ctrl_s2 "`base_ctrl' c.share_core##i.year c.share_ira##i.year c.share_r
> es##i.year c.share_debt_long##i.year c.share_debt_other##i.year"

. 
. local share_cond "!missing(share_core) & !missing(share_ira) & !missing(share
> _res) & !missing(share_debt_long) & !missing(share_debt_other)"

. 
. foreach trust_agg in trust_govt_pc1_2020 trust_govt_avg_2020 {
  2.     local agg_lab = cond("`trust_agg'"=="trust_govt_pc1_2020", "PCA (no ge
> neral)", "Avg (Medicare, Social Security)")
  3.     display _n "--- `agg_lab': `trust_agg' ---"
  4.     gen byte _samp = !missing(r5_annual_w5) & `share_cond' & !missing(`tru
> st_agg')
  5.     quietly count if _samp
  6.     display "N (obs) = " r(N)
  7. 
.     * Spec 1 (pooled, no share×year)
.     display _n "  Spec 1 (pooled):"
  8.     eststo clear
  9.     eststo m1: regress r5_annual_w5 `base_ctrl' if _samp, vce(cluster hhid
> pn)
 10.     estadd scalar p_joint_trust = . : m1
 11.     eststo m2: regress r5_annual_w5 `base_ctrl' c.`trust_agg' if _samp, vc
> e(cluster hhidpn)
 12.     estadd scalar p_joint_trust = . : m2
 13.     eststo m3: regress r5_annual_w5 `base_ctrl' c.`trust_agg' c.`trust_agg
> '#c.`trust_agg' if _samp, vce(cluster hhidpn)
 14.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 15.     estadd scalar p_joint_trust = r(p) : m3
 16.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 17. 
.     * Spec 2 (share×year)
.     display _n "  Spec 2 (share×year):"
 18.     eststo clear
 19.     eststo m1: regress r5_annual_w5 `ctrl_s2' if _samp, vce(cluster hhidpn
> )
 20.     estadd scalar p_joint_trust = . : m1
 21.     eststo m2: regress r5_annual_w5 `ctrl_s2' c.`trust_agg' if _samp, vce(
> cluster hhidpn)
 22.     estadd scalar p_joint_trust = . : m2
 23.     eststo m3: regress r5_annual_w5 `ctrl_s2' c.`trust_agg' c.`trust_agg'#
> c.`trust_agg' if _samp, vce(cluster hhidpn)
 24.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 25.     estadd scalar p_joint_trust = r(p) : m3
 26.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 27. 
.     * Spec 3 (FE + second stage)
.     display _n "  Spec 3 (FE, 2nd stage):"
 28.     local ctrl_fe "i.age_bin inlbrf married i.year"
 29.     forvalues d = 2/10 {
 30.         capture confirm variable wealth_d`d'
 31.         if !_rc local ctrl_fe "`ctrl_fe' wealth_d`d'"
 32.     }
 33.     local ctrl_fe "`ctrl_fe' c.share_core##i.year c.share_ira##i.year c.sh
> are_res##i.year c.share_debt_long##i.year c.share_debt_other##i.year"
 34. 
.     gen byte _fe_cond = `share_cond' & !missing(`trust_agg')
 35.     capture drop _fe_r5 fe_r5
 36.     quietly xtreg r5_annual_w5 `ctrl_fe' if _fe_cond, fe vce(cluster hhidp
> n)
 37.     if _rc {
 38.         display "  xtreg failed for `trust_agg'"
 39.         drop _samp _fe_cond
 40.         continue
 41.     }
 42.     predict _fe_r5 if e(sample)
 43.     bysort hhidpn: egen fe_r5 = mean(_fe_r5)
 44.     preserve
 45.     keep if !missing(fe_r5)
 46.     keep hhidpn fe_r5 educ_yrs gender race_eth born_us `trust_agg'
 47.     collapse (first) fe_r5 educ_yrs gender race_eth born_us `trust_agg', b
> y(hhidpn)
 48.     gen byte _fe_samp = !missing(fe_r5) & !missing(`trust_agg')
 49.     quietly count if _fe_samp
 50.     display "  N (persons) = " r(N)
 51.     eststo clear
 52.     eststo m1: regress fe_r5 educ_yrs i.gender i.race_eth born_us if _fe_s
> amp, vce(robust)
 53.     estadd scalar p_joint_trust = . : m1
 54.     eststo m2: regress fe_r5 educ_yrs i.gender i.race_eth born_us c.`trust
> _agg' if _fe_samp, vce(robust)
 55.     estadd scalar p_joint_trust = . : m2
 56.     eststo m3: regress fe_r5 educ_yrs i.gender i.race_eth born_us c.`trust
> _agg' c.`trust_agg'#c.`trust_agg' if _fe_samp, vce(robust)
 57.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 58.     estadd scalar p_joint_trust = r(p) : m3
 59.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 60.     restore
 61.     drop _fe_r5 fe_r5 _samp _fe_cond
 62. }

