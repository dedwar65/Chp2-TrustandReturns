. * Merge r*cesd from RAND longitudinal (all_data_merged has full RAND vars)
. preserve

. use "${CLEANED}/all_data_merged.dta", clear

. local cesd_vars "hhidpn"

. forvalues w = 6/15 {
  2.     capture confirm variable r`w'cesd
  3.     if !_rc local cesd_vars "`cesd_vars' r`w'cesd"
  4. }

. keep `cesd_vars'

. tempfile cesd

. save "`cesd'", replace
