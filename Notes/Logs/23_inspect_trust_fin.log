. xtset hhidpn year

Panel variable: hhidpn (strongly balanced)
 Time variable: year, 2000 to 2022, but with gaps
         Delta: 1 unit

. 
. * Base controls
. local base_ctrl "i.age_bin educ_yrs i.gender i.race_eth inlbrf married born_u
> s i.censreg"

. forvalues d = 2/10 {
  2.     capture confirm variable wealth_d`d'
  3.     if !_rc local base_ctrl "`base_ctrl' wealth_d`d'"
  4. }

. local ctrl_s2 "`base_ctrl' c.share_core##i.year c.share_ira##i.year c.share_r
> es##i.year c.share_debt_long##i.year c.share_debt_other##i.year"

. 
. local share_cond "!missing(share_core) & !missing(share_ira) & !missing(share
> _res) & !missing(share_debt_long) & !missing(share_debt_other)"

. 
. foreach trust_agg in trust_fin_pc1_2020 trust_fin_pc2_2020 trust_fin_avg_2020
>  {
  2.     local agg_lab = "`trust_agg'"
  3.     if "`trust_agg'"=="trust_fin_pc1_2020" local agg_lab "PC1 (no general)
> "
  4.     if "`trust_agg'"=="trust_fin_pc2_2020" local agg_lab "PC2 (no general)
> "
  5.     if "`trust_agg'"=="trust_fin_avg_2020" local agg_lab "Avg (banks, advi
> sors, mutual funds)"
  6.     display _n "--- `agg_lab': `trust_agg' ---"
  7.     gen byte _samp = !missing(r5_annual_w5) & `share_cond' & !missing(`tru
> st_agg')
  8.     quietly count if _samp
  9.     display "N (obs) = " r(N)
 10. 
.     * Spec 1 (pooled, no share×year)
.     display _n "  Spec 1 (pooled):"
 11.     eststo clear
 12.     eststo m1: regress r5_annual_w5 `base_ctrl' if _samp, vce(cluster hhid
> pn)
 13.     estadd scalar p_joint_trust = . : m1
 14.     eststo m2: regress r5_annual_w5 `base_ctrl' c.`trust_agg' if _samp, vc
> e(cluster hhidpn)
 15.     estadd scalar p_joint_trust = . : m2
 16.     eststo m3: regress r5_annual_w5 `base_ctrl' c.`trust_agg' c.`trust_agg
> '#c.`trust_agg' if _samp, vce(cluster hhidpn)
 17.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 18.     estadd scalar p_joint_trust = r(p) : m3
 19.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 20. 
.     * Spec 2 (share×year)
.     display _n "  Spec 2 (share×year):"
 21.     eststo clear
 22.     eststo m1: regress r5_annual_w5 `ctrl_s2' if _samp, vce(cluster hhidpn
> )
 23.     estadd scalar p_joint_trust = . : m1
 24.     eststo m2: regress r5_annual_w5 `ctrl_s2' c.`trust_agg' if _samp, vce(
> cluster hhidpn)
 25.     estadd scalar p_joint_trust = . : m2
 26.     eststo m3: regress r5_annual_w5 `ctrl_s2' c.`trust_agg' c.`trust_agg'#
> c.`trust_agg' if _samp, vce(cluster hhidpn)
 27.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 28.     estadd scalar p_joint_trust = r(p) : m3
 29.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 30. 
.     * Spec 3 (FE + second stage)
.     display _n "  Spec 3 (FE, 2nd stage):"
 31.     local ctrl_fe "i.age_bin inlbrf married i.year"
 32.     forvalues d = 2/10 {
 33.         capture confirm variable wealth_d`d'
 34.         if !_rc local ctrl_fe "`ctrl_fe' wealth_d`d'"
 35.     }
 36.     local ctrl_fe "`ctrl_fe' c.share_core##i.year c.share_ira##i.year c.sh
> are_res##i.year c.share_debt_long##i.year c.share_debt_other##i.year"
 37. 
.     gen byte _fe_cond = `share_cond' & !missing(`trust_agg')
 38.     capture drop _fe_r5 fe_r5
 39.     quietly xtreg r5_annual_w5 `ctrl_fe' if _fe_cond, fe vce(cluster hhidp
> n)
 40.     if _rc {
 41.         display "  xtreg failed for `trust_agg'"
 42.         drop _samp _fe_cond
 43.         continue
 44.     }
 45.     predict _fe_r5 if e(sample)
 46.     bysort hhidpn: egen fe_r5 = mean(_fe_r5)
 47.     preserve
 48.     keep if !missing(fe_r5)
 49.     keep hhidpn fe_r5 educ_yrs gender race_eth born_us `trust_agg'
 50.     collapse (first) fe_r5 educ_yrs gender race_eth born_us `trust_agg', b
> y(hhidpn)
 51.     gen byte _fe_samp = !missing(fe_r5) & !missing(`trust_agg')
 52.     quietly count if _fe_samp
 53.     display "  N (persons) = " r(N)
 54.     eststo clear
 55.     eststo m1: regress fe_r5 educ_yrs i.gender i.race_eth born_us if _fe_s
> amp, vce(robust)
 56.     estadd scalar p_joint_trust = . : m1
 57.     eststo m2: regress fe_r5 educ_yrs i.gender i.race_eth born_us c.`trust
> _agg' if _fe_samp, vce(robust)
 58.     estadd scalar p_joint_trust = . : m2
 59.     eststo m3: regress fe_r5 educ_yrs i.gender i.race_eth born_us c.`trust
> _agg' c.`trust_agg'#c.`trust_agg' if _fe_samp, vce(robust)
 60.     quietly testparm c.`trust_agg' c.`trust_agg'#c.`trust_agg'
 61.     estadd scalar p_joint_trust = r(p) : m3
 62.     esttab m1 m2 m3, se star(* 0.10 ** 0.05 *** 0.01) b(2) se(2) stats(N r
> 2_a p_joint_trust)
 63.     restore
 64.     drop _fe_r5 fe_r5 _samp _fe_cond
 65. }

