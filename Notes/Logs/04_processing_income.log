> _lab_inc_final_`yprev' ///
>             if !missing(ln_lab_inc_final_`y') & !missing(ln_lab_inc_final_`yp
> rev')
  6.         gen double ln_tot_inc_final_growth_`y' = ln_tot_inc_final_`y' - ln
> _tot_inc_final_`yprev' ///
>             if !missing(ln_tot_inc_final_`y') & !missing(ln_tot_inc_final_`yp
> rev')
  7.         local labgrowth "`labgrowth' ln_lab_inc_final_growth_`y'"
  8.         local totgrowth "`totgrowth' ln_tot_inc_final_growth_`y'"
  9.     }
 10. }
