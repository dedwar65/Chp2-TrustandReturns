. * ----------------------------------------------------------------------
. * 5) 2SLS second stage by instrument scheme (r5 only)
. * ----------------------------------------------------------------------
. display _n "#################################################################
> #######"

########################################################################

. display "5) 2SLS SECOND STAGE BY INSTRUMENT SCHEME (r5 ONLY)"
5) 2SLS SECOND STAGE BY INSTRUMENT SCHEME (r5 ONLY)

. display "####################################################################
> ####"
########################################################################

. 
. foreach s of local scheme_list {
  2.     if !`scheme_has_`s'' continue
  3. 
.     local scheme_label "`scheme_label_`s''"
  4.     local instrs "`scheme_instr_`s''"
  5.     local reg_ctrls "`scheme_ctrls_`s''"
  6.     local has_gender_ctrl `scheme_has_gender_`s''
  7. 
.     display _n "#############################################################
> ###########"
  8.     display "`scheme_label'"
  9.     display "#############################################################
> ###########"
 10.     display "Excluded instruments: `instrs'"
 11. 
.     local wealth_test_list "`wealth_r5_vars'"
 12. 
.     display _n "-------------------------------------------------------------
> ----------"
 13.     display "Outcome: r5_annual_avg_w5"
 14.     display "Regressions use listwise deletion; N may differ across models
> ."
 15.     display "Included exogenous controls: `reg_ctrls'"
 16.     display "Excluded instruments: `instrs'"
 17.     display "-------------------------------------------------------------
> ----------"
 18. 
.     local y "r5_annual_avg_w5"
 19. 
.     ivregress 2sls `y' `reg_ctrls' ///
>         (trust_others_2020 trust_others_2020_sq = `instrs'), vce(robust)
 20.     estimates store iv_`s'
 21. 
.     display _n "--- IV diagnostics: built-in (ivregress) ---"
 22.     capture noisily estat firststage
 23.     if _rc display as txt "estat firststage unavailable for this specifica
> tion."
 24.     capture noisily estat endogenous
 25.     if _rc display as txt "estat endogenous unavailable for this specifica
> tion."
 26.     capture noisily estat overid
 27.     if _rc display as txt "estat overid unavailable for this specification
> ."
 28.     capture noisily estat weakrobust
 29.     if _rc display as txt "estat weakrobust unavailable for this specifica
> tion."
 30. 
.     display _n "--- IV diagnostics: explicit weakrobust AR/CLR ---"
 31.     capture noisily estat weakrobust, ar betanull(0 0, copy)
 32.     if _rc display as txt "estat weakrobust AR unavailable for this specif
> ication."
 33.     capture noisily estat weakrobust, clr betanull(0 0, copy)
 34.     if _rc display as txt "estat weakrobust CLR unavailable for this speci
> fication."
 35. 
.     display _n "--- IV diagnostics: ivreg2 weak-ID suite ---"
 36.     capture noisily ivreg2 `y' `reg_ctrls' ///
>         (trust_others_2020 trust_others_2020_sq = `instrs'), ///
>         robust first
 37.     if _rc display as txt "ivreg2 diagnostics unavailable for this specifi
> cation."
 38. 
.     estimates restore iv_`s'
 39.     display "--- Joint test: Trust and trust squared ---"
 40.     testparm trust_others_2020 trust_others_2020_sq
 41.     if trim("`wealth_test_list'") != "" {
 42.         display "--- Joint test: Wealth deciles ---"
 43.         testparm `wealth_test_list'
 44.     }
 45.     if trim("`reg_ctrl_age'") != "" {
 46.         display "--- Joint test: Age bins ---"
 47.         testparm i.age_bin
 48.     }
 49.     if trim("`reg_ctrl_educ'") != "" {
 50.         display "--- Joint test: Education categories ---"
 51.         testparm i.educ_cat
 52.     }
 53.     if `has_gender_ctrl' & trim("`reg_ctrl_gender'") != "" {
 54.         display "--- Joint test: Gender ---"
 55.         testparm i.gender
 56.     }
 57. }

